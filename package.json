          "parser": "angular"
        }
      }
    ]
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.4",
    "@angular/compiler": "21.2.4",
    "@angular/core": "21.2.4",
    "@angular/forms": "21.2.4",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.4",
    "@angular/router": "21.2.4",
    "ajv": "8.18.0",
    "js-yaml": "4.1.1",
    "lodash-es": "4.17.23",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.4",
    "@angular/material": "21.2.2",
    "@tailwindcss/postcss": "4.2.2",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "4.17.12",
    "jsdom": "29.0.1",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
