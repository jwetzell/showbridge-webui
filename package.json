{
  "name": "@showbridge/webui",
  "version": "0.11.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format:write": "prettier ./ --write"
